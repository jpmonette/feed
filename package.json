{
  "name": "feed",
  "version": "5.2.1",
  "type": "module",
  "description": "Feed is a RSS, Atom and JSON feed generator for Node.js, making content syndication simple and intuitive!",
  "homepage": "https://github.com/jpmonette/feed",
  "author": "Jean-Philippe Monette <contact@jpmonette.net>",
  "license": "MIT",
  "main": "lib/feed.js",
  "types": "lib/feed.d.ts",
  "exports": {
    ".": {
      "import": "./lib/feed.js",
      "require": "./lib/feed.js",
      "types": "./lib/feed.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "!**/*.map",
    "lib"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublish": "pnpm build",
    "test": "vitest run",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format src",
    "format:fix": "biome format --write src"
  },
  "keywords": [
    "rss",
    "atom",
    "feed",
    "syndication",
    "xml",
    "wrapper",
    "blog"
  ],
  "dependencies": {
    "xml-js": "^1.6.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "tsdown": "^0.11.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "bugs": {
    "url": "https://github.com/jpmonette/feed/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jpmonette/feed.git"
  },
  "packageManager": "pnpm@10.10.0+sha512.d615db246fe70f25dcfea6d8d73dee782ce23e2245e3c4f6f888249fb568149318637dca73c2c5c8ef2a4ca0d5657fb9567188bfab47f566d1ee6ce987815c39"
}
